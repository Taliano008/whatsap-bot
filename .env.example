# ── WhatsApp / Meta ──────────────────────────────────────────
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=1017797598092582
WHATSAPP_BUSINESS_ACCOUNT_ID=730601153414197
WEBHOOK_VERIFY_TOKEN=pick_any_secret_string_you_want

# ── Anthropic (Claude) ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Sheets ─────────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Name of the worksheet tab inside the Google Sheet (check the tab at the bottom of the sheet)
GOOGLE_SHEET_TAB_NAME=Inventory
# Path to your downloaded service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/google-service-account.json

# ── Shop identity (used in system prompt) ────────────────────
SHOP_NAME=TechHub Electronics
SHOP_LOCATION=Nairobi, Kenya
SHOP_PHONE=+254 700 000000
SHOP_EMAIL=info@techhub.co.ke
SHOP_HOURS=Mon–Sat 8am–7pm, Sun 10am–4pm
MPESA_PAYBILL=123456

# ── Redis (sessions) ─────────────────────────────────────────
# Full connection string — get password from Redis Cloud dashboard
# Format: redis://:PASSWORD@redis-13521.c57.us-east-1-4.ec2.cloud.redislabs.com:13521
REDIS_URL=redis://:your_redis_password@redis-13521.c57.us-east-1-4.ec2.cloud.redislabs.com:13521

# ── Human handoff ─────────────────────────────────────────────
# Your personal WhatsApp number (no + sign) — receives handoff alerts
# and can send #bot (or #bot <customer_phone>) to resume the bot
OWNER_PHONE=254745247600

# Set to "false" to disable automatic customer notifications on order status updates
ORDER_NOTIFY=true
